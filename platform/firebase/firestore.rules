rules_version = '2';

// LyfeLabz Firestore Security Rules
// Sprint 2 Step 7: first narrowly-scoped affirmative rules over the
// Sprint 1 default-deny baseline. Every other path remains default-deny.
//
// Scope opened in this pass:
//   users/{uid}     - self get; self update limited to { displayName }.
//   schools/{id}    - authenticated get; no list; no writes.
//   classes/{id}    - owning-teacher get; owning-teacher list only via
//                     teacherId equality on their own uid; no writes.
//   auditEvents/{}  - server-only. No client reads or writes.
//
// Every collection not matched below inherits the terminal deny rule at
// the bottom of the file. New rules must be additive and narrowly scoped;
// existing rules must not be weakened.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Sprint 2 fixed allowlist of self-mutable fields on users/{uid}.
    // Extending this allowlist is a repository-level decision and must
    // be paired with new Rules tests per Engineering Standards §9.
    function affectedKeysAreAllowlisted() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(["displayName"]);
    }

    // ---------- users/{uid} ----------
    //
    // Self read only. Self update limited to the { displayName } allowlist.
    // Every other field (authUid, role, schoolId, status, createdAt,
    // email, grade, consentState, teacherProfile, studentProfile) is
    // server-managed and denied to clients. Cross-user reads denied.
    // create/delete remain server-only.
    match /users/{uid} {
      allow get: if isSelf(uid);
      allow update: if isSelf(uid) && affectedKeysAreAllowlisted();
    }

    // ---------- schools/{schoolId} ----------
    //
    // Any authenticated caller may get a school document. The Sprint 2
    // Data Model defines the client-visible metadata as name, shortName,
    // and timezone; per Data Model §3.2 the collection carries no
    // non-metadata fields that must be hidden from clients, so the
    // allowlist is enforced by the write path (server-only) rather than
    // by the read rule. List and every write are denied.
    match /schools/{schoolId} {
      allow get: if isSignedIn();
    }

    // ---------- classes/{classId} ----------
    //
    // Sprint 4B Classroom Foundation.
    //
    // Reads:
    //   - `get`: the owning teacher may read their own class document. A
    //     classroom's `teacherId` is set at creation and never changes
    //     (Data Model §1.2), so ownership can be authorized on the
    //     document itself without a second read.
    //   - `list`: the owning teacher may list only classes they own. The
    //     Rules engine sees the incoming query's `resource` per matched
    //     document; requiring `resource.data.teacherId == request.auth.uid`
    //     forces every list query to be scoped by owner and prevents a
    //     cross-teacher or cross-school enumeration. The Rules engine
    //     additionally requires the client query to include the matching
    //     `teacherId` filter for the rule to be admissible.
    //
    // Writes:
    //   - All client writes remain denied. `classesCreate`,
    //     `classesUpdateMetadata`, and `classesArchive` write through the
    //     Admin SDK from the Cloud Function trust boundary and therefore
    //     bypass Rules. Direct client `create`, `update`, or `delete`
    //     against classes/{classId} is denied by the terminal deny rule.
    match /classes/{classId} {
      allow get: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;
    }

    // ---------- enrollments/{enrollmentId} ----------
    //
    // Sprint 4C Enrollment Foundation.
    //
    // Reads:
    //   - `get`: two admissible callers per Security Model §4.4.
    //       * The enrolled student may get their own enrollment. The
    //         document carries `studentId` directly per Data Model §3.4,
    //         so authorization is decided on the document itself with no
    //         second read.
    //       * The teacher of the referenced class may get any enrollment
    //         in a class they own. Enrollments do not carry `teacherId`,
    //         so ownership is resolved by a get() against the referenced
    //         `classes/{classId}` document. Immutable ownership per Data
    //         Model §1.2 guarantees the traversed teacherId cannot drift.
    //   - `list`: two admissible query shapes.
    //       * A student query filtered by `studentId == request.auth.uid`
    //         returns only their own enrollments.
    //       * A teacher query filtered by `classId == C` returns the
    //         roster for a single class they own; the teacher-ownership
    //         check is a get() against `classes/{classId}`.
    //     Every other list shape (unscoped, cross-student, cross-class)
    //     is denied.
    //
    // Writes:
    //   - All client writes remain denied. `enrollmentsJoinByCode`,
    //     `enrollmentsTeacherAdd`, and `enrollmentsSetStatus` write
    //     through the Admin SDK from the Cloud Function trust boundary
    //     and therefore bypass Rules. Direct client `create`, `update`,
    //     or `delete` against enrollments/{enrollmentId} is denied by the
    //     terminal deny rule.
    match /enrollments/{enrollmentId} {
      allow get: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || (
          exists(/databases/$(database)/documents/classes/$(resource.data.classId))
          && get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId == request.auth.uid
        )
      );
      allow list: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || (
          exists(/databases/$(database)/documents/classes/$(resource.data.classId))
          && get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId == request.auth.uid
        )
      );
    }

    // ---------- assignments/{assignmentId} ----------
    //
    // Sprint 4D Assignment Foundation.
    //
    // Reads:
    //   - `get`: the owning teacher may read their own assignment
    //     document. An assignment's `teacherId` is set at creation and
    //     never changes (Data Model §1.2 and §3.6), so ownership can be
    //     authorized on the document itself without a second read.
    //   - `list`: the owning teacher may list only assignments they own.
    //     Requiring `resource.data.teacherId == request.auth.uid` forces
    //     every list query to be scoped by owner and prevents a
    //     cross-teacher or cross-school enumeration. The Rules engine
    //     additionally requires the client query to include the matching
    //     `teacherId` filter for the rule to be admissible.
    //
    // Student assignment reads are intentionally deferred to a future
    // sprint; the terminal deny rule denies them.
    //
    // Writes:
    //   - All client writes remain denied. `assignmentsCreateDraft`,
    //     `assignmentsUpdateDraft`, `assignmentsPublish`,
    //     `assignmentsClose`, and `assignmentsArchive` write through the
    //     Admin SDK from the Cloud Function trust boundary and therefore
    //     bypass Rules. Direct client `create`, `update`, or `delete`
    //     against assignments/{assignmentId} is denied by the terminal
    //     deny rule.
    match /assignments/{assignmentId} {
      allow get: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;

      // ---------- assignments/{assignmentId}/recipients/{studentId} ----------
      //
      // Sprint 12E Slice 2A (PDR-029h, Sprint 12E-A Reconciliation Notice
      // on the Firestore Data Model and Cloud Function Charter).
      //
      // Canonical frozen assignment-recipient membership record. Document
      // identifier equals the canonical `studentId` so exactly one
      // recipient exists per (assignmentId, studentId) pair.
      //
      // Reads:
      //   - Every direct client read is denied. The recipient collection is
      //     the historical population authority; it is not the surface
      //     rendered to teachers or students. Teacher aggregate metrics
      //     flow through `assessmentAssignmentSummary`; per-student
      //     recipient status is exposed only through certified callables
      //     that project bounded fields. Neither a teacher nor a student
      //     is authorized to list or get a recipient document directly,
      //     which prevents cross-class, cross-school, cross-district
      //     enumeration and student cross-recipient discovery.
      //
      // Writes:
      //   - Every direct client write is denied and denied explicitly
      //     rather than through the terminal deny alone, to document the
      //     PDR-029h append-only recipient invariant at the surface with
      //     the strongest immutability requirement. `assignmentsPublish`
      //     (initial snapshot) and `assignmentsRecipientAdd` (manual late
      //     addition) are the sole writers and both run through the Admin
      //     SDK from the Cloud Function trust boundary.
      match /recipients/{studentId} {
        allow read: if false;
        allow create, update, delete: if false;
      }
    }

    // ---------- submissions/{submissionId} ----------
    //
    // Sprint 5A Submission Foundation.
    //
    // Reads:
    //   - `get`: two admissible callers per Security Model §4.6.
    //       * The submitting student may get their own submission. The
    //         document carries `studentId` directly per Data Model §3.7,
    //         so authorization is decided on the document itself with no
    //         second read.
    //       * The teacher of the referenced assignment may get any
    //         submission belonging to a classroom they own. The
    //         submission carries `teacherId` denormalized from the
    //         assignment per §12.3; immutable ownership per §1.2
    //         guarantees this cannot drift.
    //   - `list`: two admissible query shapes.
    //       * A student query filtered by `studentId == request.auth.uid`
    //         returns only their own submissions.
    //       * A teacher query filtered by `teacherId == request.auth.uid`
    //         returns only submissions in classrooms they own. The Rules
    //         engine additionally requires the client query to include
    //         the matching filter for the rule to be admissible.
    //     Every other list shape (unscoped, cross-student, cross-teacher,
    //     cross-school) is denied.
    //
    // Writes:
    //   - All client writes remain denied. `submissionsCreate` and
    //     `submissionsFinalize` write through the Admin SDK from the
    //     Cloud Function trust boundary and therefore bypass Rules.
    //     Direct client `create`, `update`, or `delete` against
    //     submissions/{submissionId} is denied by the terminal deny rule.
    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || resource.data.teacherId == request.auth.uid
      );
      allow list: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || resource.data.teacherId == request.auth.uid
      );
    }

    // ---------- lmsProviders/{providerId} ----------
    //
    // LMS Integration Foundation (PDR-020c, Data Model §2.9.a). Closed
    // reference set of supported LMS providers. Read-only reference data
    // that carries no PII and no token material. Any authenticated caller
    // may get and list so the Teacher Workspace can render the
    // Settings > Integrations surface without hardcoding provider
    // identifiers on the client. Every write is server-only.
    match /lmsProviders/{providerId} {
      allow get, list: if isSignedIn();
    }

    // ---------- lmsConnections/{connectionId} ----------
    //
    // LMS Integration Foundation (PDR-020c, Data Model §2.9.a,
    // Amendment §3.3). One document per (teacher, provider) pair. The
    // token reference field is server-only per PDR-019e; even the owning
    // teacher receives only the mirror-visible fields, and the token
    // itself never lives in Firestore. The mirror record is scoped to the
    // owning teacher through the denormalized `teacherId` field per
    // Amendment §3.4.
    //
    // Reads:
    //   - `get`: the owning teacher may read their own connection. The
    //     `tokenRef` field is present on the record but is not a token; it
    //     is an opaque server-side pointer. The token store never resolves
    //     it for a client-originated read.
    //   - `list`: the owning teacher may list only connections they own
    //     (teacherId equality).
    //
    // Writes:
    //   - All client writes remain denied. `lmsConnectionsBegin`,
    //     `lmsConnectionsComplete`, `lmsConnectionsDescribe`, and
    //     `lmsConnectionsDisconnect` write through the Admin SDK from the
    //     Cloud Function trust boundary and therefore bypass Rules.
    match /lmsConnections/{connectionId} {
      allow get: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;
    }

    // ---------- lmsClassLinks/{linkId} ----------
    //
    // LMS Integration Foundation (PDR-020c, Data Model §2.9.a,
    // Amendment §3.3). One document per (LyfeLabz class, LMS class) pair.
    // Owner-teacher-scoped through the denormalized `ownerUid` per
    // Amendment §3.4.
    //
    // Reads:
    //   - `get`: the owning teacher may read a link for a class they own.
    //     Ownership is authorized on the document's `ownerUid`
    //     denormalization; the class ownership immutability guarantee
    //     (PDR-005) ensures this cannot drift.
    //   - `list`: the owning teacher may list only links they own.
    //
    // Writes:
    //   - All client writes remain denied. `lmsClassesImport` writes
    //     through the Admin SDK from the Cloud Function trust boundary.
    match /lmsClassLinks/{linkId} {
      allow get: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ---------- lmsAssignmentPublications/{publicationId} ----------
    //
    // LMS Integration Foundation (Sprint 8D authorized scope expansion,
    // Data Model §2.9.a, Amendment §3.3). One document per publication
    // attempt from a LyfeLabz assignment to an LMS class. The publishing
    // teacher is the sole client-side reader per Amendment §3.3; the
    // record is scoped to the owning teacher through the denormalized
    // `ownerUid` per Amendment §3.4.
    //
    // Reads:
    //   - `get`: the publishing teacher may read a publication record
    //     they authored. Ownership is authorized on the document's
    //     `ownerUid` denormalization.
    //   - `list`: the publishing teacher may list only publications
    //     they authored.
    //
    // Writes:
    //   - All client writes remain denied. `lmsAssignmentsPublish`
    //     writes through the Admin SDK from the Cloud Function trust
    //     boundary and therefore bypasses Rules.
    match /lmsAssignmentPublications/{publicationId} {
      allow get: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ---------- Assessment helpers ----------
    //
    // Sprint 12B Slice 1 (PDR-025, PDR-026). Small, stateless helpers used
    // only by the five assessment collection blocks below. Each helper reads
    // trusted values only (request.auth.token.* and the target document's
    // immutable ownership fields on resource.data). None of these helpers
    // call get() or exists(); assessment session and attempt authorization
    // is decided on the document itself, in accordance with the certified
    // access matrix in SPRINT_12A_ASSESSMENT_DATA_ACCESS_REVIEW.md §14.
    function matchesResourceDistrict() {
      return request.auth.token.districtId is string
        && request.auth.token.districtId.size() > 0
        && resource.data.districtId == request.auth.token.districtId;
    }

    function isOwningStudent() {
      return resource.data.studentId == request.auth.uid;
    }

    function isOwningTeacher() {
      return resource.data.teacherId == request.auth.uid;
    }

    // ---------- assessments/{assessmentId} ----------
    //
    // Sprint 12B Slice 1 (PDR-026). Assessment metadata pointer. Carries no
    // answer-key material, no student data, and no district scope
    // (assessment content is district-neutral per PDR-026 and Contract §11).
    //
    // Reads:
    //   - `get`: any authenticated caller. Required so students can render
    //     assessment metadata and teachers can render assessment metadata
    //     for their class assignments.
    //   - `list` is not enabled; the assessment content surface is
    //     addressable by known assessmentId and does not require collection
    //     enumeration.
    //
    // Writes:
    //   - All client writes denied. The deployment pipeline
    //     (`deployAssessmentRevision`) is the sole writer and runs through
    //     the Admin SDK, bypassing Rules.
    match /assessments/{assessmentId} {
      allow get: if isSignedIn();
    }

    // ---------- assessmentRevisions/{revisionId} ----------
    //
    // Sprint 12B Slice 1 (PDR-026, ASSESSMENT_SCORING_CONTRACT §6). The
    // scorable content shape. The deployment pipeline enforces that this
    // document carries no correct-answer material; the paired
    // `assessmentAnswerKeys/{revisionId}` document holds the answer key.
    //
    // Reads:
    //   - `get`: any authenticated caller. Immutable after write.
    //   - `list` is not enabled.
    //
    // Writes:
    //   - All client writes denied. `deployAssessmentRevision` creates the
    //     document under Admin SDK authority and never mutates it.
    match /assessmentRevisions/{revisionId} {
      allow get: if isSignedIn();
    }

    // ---------- assessmentAnswerKeys/{revisionId} ----------
    //
    // Sprint 12B Slice 1 (PDR-026d, ASSESSMENT_IMPLEMENTATION_CONTRACT §22,
    // LYFELABZ_FIREBASE_SECURITY_MODEL Sprint 9A Reconciliation Notice).
    // Correct-answer material and per-item explanations. Server-confidential
    // for every role including `platformAdministrator`.
    //
    // The sole authorized reader is the scorer inside
    // `assessmentAttemptsFinalize`, which runs under Admin SDK authority
    // and bypasses Rules. The permitted answer-key subset
    // (`correctOptionId`, `explanation`) is delivered to the student only
    // through their own `attempts/{attemptId}` document per
    // ASSESSMENT_SCORING_CONTRACT §10.4.
    //
    // This block is intentionally more restrictive than the terminal deny:
    // an explicit `allow read, write: if false;` documents the confidentiality
    // contract at the surface with the strongest confidentiality requirement
    // and prevents accidental future relaxation by a broader edit.
    match /assessmentAnswerKeys/{revisionId} {
      allow read, write: if false;
    }

    // ---------- assessmentSessions/{sessionId} ----------
    //
    // Sprint 12B Slice 1 (PDR-025e, PDR-026, ASSESSMENT_IMPLEMENTATION_CONTRACT
    // §6, §22). Transient per-student working state during a Live attempt.
    //
    // Reads:
    //   - `get`: only the owning student, and only when the caller's
    //     verified `districtId` claim matches the session's frozen
    //     `districtId`. Ownership fields on the session are frozen at
    //     creation (`assessment-sessions-begin.ts:345-357`), so both
    //     comparisons are decidable on the document itself without a
    //     second read.
    //   - Teachers do NOT read live sessions per PDR-026. This is
    //     intentional and is a client-boundary invariant.
    //   - `list` is not enabled.
    //
    // Writes:
    //   - All client writes denied. `assessmentSessionsBegin` (create),
    //     `assessmentSessionsAutosave` (narrow update), and
    //     `assessmentAttemptsFinalize` (delete inside the finalize
    //     transaction) write through the Admin SDK from the Cloud Function
    //     trust boundary and therefore bypass Rules.
    match /assessmentSessions/{sessionId} {
      allow get: if isSignedIn()
        && isOwningStudent()
        && matchesResourceDistrict();
    }

    // ---------- attempts/{attemptId} ----------
    //
    // Sprint 12B Slice 1 (PDR-025e, PDR-026a, PDR-026c,
    // ASSESSMENT_IMPLEMENTATION_CONTRACT §7, §22, ASSESSMENT_SCORING_CONTRACT
    // §10.4). Immutable authoritative record of a scored assessment attempt.
    //
    // Reads:
    //   - `get`: either the owning student (matched by `studentId`) or the
    //     owning teacher (matched by the denormalized `teacherId`), and in
    //     both cases the caller's verified `districtId` claim MUST match
    //     the attempt's frozen `districtId`. `teacherId` on `attempts` is
    //     the class's owning teacher, denormalized through the session
    //     from the assignment (`assessment-attempts-finalize.ts:797-815`);
    //     immutable class ownership per PDR-005 guarantees this cannot
    //     drift and therefore serves as the class-ownership proxy the Rule
    //     evaluates on the document itself. Same-district access alone is
    //     NOT sufficient; ownership is also required.
    //   - `list` is not enabled in Sprint 12B; collection-scoped attempt
    //     queries are the deliverable of the rollup slice.
    //
    // Writes:
    //   - All direct client writes denied, and denied explicitly rather
    //     than through the terminal deny alone, to document the PDR-026a
    //     immutability invariant on the surface with the strongest
    //     immutability requirement. `assessmentAttemptsFinalize` is the
    //     sole writer and runs through the Admin SDK.
    match /attempts/{attemptId} {
      allow get: if isSignedIn()
        && matchesResourceDistrict()
        && (isOwningStudent() || isOwningTeacher());
      allow create, update, delete: if false;
    }

    // ---------- auditEvents/{eventId} ----------
    //
    // Append-only server-write, server-read per Security Model §11 and
    // Cloud Function Charter §2. This match block is present only to
    // make the server-only intent explicit; every client operation
    // remains denied.
    match /auditEvents/{eventId} {
      allow read, write: if false;
    }

    // ---------- Terminal default-deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
